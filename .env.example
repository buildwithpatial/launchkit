# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {origin}/api/auth/callback/google
AUTH_GOOGLE_ID=****
AUTH_GOOGLE_SECRET=****

# Apple Sign in with Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
# AUTH_APPLE_SECRET is a JWT generated from your Apple key — see https://authjs.dev/getting-started/providers/apple
# Authorized redirect URI: {origin}/api/auth/callback/apple
AUTH_APPLE_ID=****
AUTH_APPLE_SECRET=****

# Gemini API key (https://aistudio.google.com/apikey)
# Powers all AI surfaces: chat, text demo, image demo. @ai-sdk/google reads this.
GOOGLE_GENERATIVE_AI_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Razorpay (https://dashboard.razorpay.com/app/keys)
# Use test-mode keys (rzp_test_*) in development.
# Webhook secret is configured per-endpoint at https://dashboard.razorpay.com/app/webhooks
RAZORPAY_KEY_ID=****
RAZORPAY_KEY_SECRET=****
RAZORPAY_WEBHOOK_SECRET=****
NEXT_PUBLIC_RAZORPAY_KEY_ID=****
